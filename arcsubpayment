// MODAL HELPERS
// ══════════════════════════════════════════════
function closeModal(id) {
  document.getElementById(id).style.display = 'none'
}

// ══════════════════════════════════════════════
// TOASTS
// ══════════════════════════════════════════════
let toastTimer = {}
function toast(title, sub, icon='✓') {
  const wrap = document.getElementById('toast-wrap')
  const id   = 't_' + Date.now()
  const el   = document.createElement('div')
  el.id = id
  el.className = 'toast'
  const iconColor = icon==='✅'?'var(--green)':icon==='🔴'?'var(--red)':'var(--cyan)'
  el.innerHTML = `
    <span class="toast-icon" style="color:${iconColor}">${icon}</span>
    <div style="flex:1"><div class="toast-title">${title}</div><div class="toast-sub">${sub}</div></div>
    <button class="toast-x" onclick="document.getElementById('${id}').remove()">×</button>`
  wrap.appendChild(el)
  toastTimer[id] = setTimeout(() => { const t=document.getElementById(id); if(t) t.remove() }, 5000)
  // max 4 toasts
  while(wrap.children.length > 4) wrap.removeChild(wrap.firstChild)
}

// ══════════════════════════════════════════════
// KEYBOARD
// ══════════════════════════════════════════════
document.addEventListener('keydown', e => {
  if (e.key==='Escape') {
    ['modal-subscribe','modal-create','modal-charge'].forEach(closeModal)
    closeWalletModal()
  }
})

