// ══════════════════════════════════════════════
// UTC CLOCK — ticks every second
// ══════════════════════════════════════════════
function tickClock() {
  const now  = new Date()
  const d    = now.toISOString().slice(0,10)
  const t    = now.toISOString().slice(11,19)
  document.getElementById('utc-clock').textContent = `${d} ${t} UTC`
}
