  const grid = document.getElementById('plan-grid')
  if (!grid) return
  grid.innerHTML = filtered.map(p => `
    <div class="plan-card" onclick="openSubscribeModal(${p.id})">
      <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,${p.color}88,transparent)"></div>
      <div style="font-family:var(--font-m);font-size:10px;color:var(--text-2);margin-bottom:10px;display:flex;align-items:center;gap:6px">
