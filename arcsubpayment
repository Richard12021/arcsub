// ══════════════════════════════════════════════
function openSubscribeModal(planId) {
  const plan = PLANS.find(p => p.id === planId)
  if (!plan) return
  STATE.activePlan = planId
  const fee = (plan.price * 0.025).toFixed(4)
  const net = (plan.price - fee).toFixed(4)
  document.getElementById('sub-modal-body').innerHTML = `
    <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px;margin-bottom:16px">
      <div style="display:flex;align-items:center;gap:14px">
        <div style="width:44px;height:44px;border-radius:10px;background:${plan.color}22;border:1px solid ${plan.color}44;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">💎</div>
        <div style="flex:1">
          <div style="font-family:var(--font-d);font-weight:600;font-size:16px;margin-bottom:3px">${plan.name}</div>
          <div style="font-family:var(--font-m);font-size:11px;color:var(--text-2)">Plan #${plan.id} · ${plan.merchant.slice(0,8)}…</div>
        </div>
        <div style="text-align:right">
          <div style="font-family:var(--font-m);font-size:22px;color:${plan.color}">${plan.price}</div>
          <div style="font-family:var(--font-m);font-size:10px;color:var(--text-2)">${plan.token} / ${plan.interval.toLowerCase()}</div>
        </div>
      </div>
      ${plan.trial>0?`<div style="margin-top:10px;background:var(--green-dim);border:1px solid rgba(60,240,160,.2);border-radius:6px;padding:8px 12px;font-size:12px;color:var(--green)">✓ ${plan.trial}-day free trial — first charge after trial ends</div>`:''}
    </div>
    <div style="background:var(--gold-dim);border:1px solid rgba(240,184,64,.2);border-radius:var(--r-md);padding:12px 14px;margin-bottom:14px;font-size:12px;color:var(--gold);display:flex;gap:10px">
      <span style="flex-shrink:0">⚠️</span>
      <div><strong>Two-step:</strong> First approve USDC allowance (max, once), then subscribe. Funds are deducted immediately.</div>
    </div>
    <div style="background:var(--bg-0);border:1px solid var(--border);border-radius:var(--r-md);padding:14px;margin-bottom:18px">
      <div class="breakdown-row"><span style="color:var(--text-1)">Plan price</span><span style="font-family:var(--font-m);font-size:12px">${plan.price}.00 ${plan.token}</span></div>
      <div class="breakdown-row"><span style="color:var(--text-1)">Platform fee (2.5%)</span><span style="font-family:var(--font-m);font-size:12px;color:var(--text-2)">${fee} ${plan.token}</span></div>
      <div class="breakdown-row"><span style="color:var(--text-1)">Merchant receives</span><span style="font-family:var(--font-m);font-size:12px;color:var(--green)">${net} ${plan.token}</span></div>
      <div class="breakdown-row total"><span>You pay now</span><span>${plan.trial>0?'Free (trial)':plan.price+' '+plan.token}</span></div>
    </div>
    <div style="display:flex;gap:10px;justify-content:flex-end">
      <button class="btn-ghost" onclick="closeModal('modal-subscribe')">Cancel</button>
      <button class="btn-primary" id="sub-btn" onclick="confirmSubscribe(${planId})" ${!STATE.connected?'disabled':''}>
        ${STATE.connected?'Approve & Subscribe →':'Connect Wallet First'}
      </button>
    </div>`
  document.getElementById('modal-subscribe').style.display = ''
}

function confirmSubscribe(planId) {
  const plan = PLANS.find(p => p.id === planId)
  if (!plan) return
  const btn = document.getElementById('sub-btn')
  btn.disabled = true
  btn.innerHTML = '<span style="animation:spin .8s linear infinite;display:inline-block">↻</span> Approving USDC…'
  setTimeout(() => {
    btn.innerHTML = '<span style="animation:spin .8s linear infinite;display:inline-block">↻</span> Subscribing…'
    setTimeout(() => {
      closeModal('modal-subscribe')
      if (plan.trial === 0) {
        deductBalance(plan.price, plan.name)
      } else {
        toast('Subscribed!', `${plan.name} · ${plan.trial}d trial started`, '✅')
      }
      renderDashboard()
    }, 1400)
  }, 1200)
}

