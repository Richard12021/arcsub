<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ArcSub — Recurring Payments on Arc</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg-0:#04060e; --bg-1:#080d1a; --bg-2:#0d1525; --bg-3:#121c30; --bg-4:#1a2540;
  --border:rgba(56,90,148,0.28); --border-hi:rgba(56,160,220,0.45);
  --cyan:#38c8f0; --cyan-dim:rgba(56,200,240,0.10);
  --gold:#f0b840; --gold-dim:rgba(240,184,64,0.10);
  --green:#3cf0a0; --green-dim:rgba(60,240,160,0.08);
  --red:#f05060; --red-dim:rgba(240,80,96,0.08);
  --purple:#9b7ff0;
  --text-0:#e8edf8; --text-1:#9aaac8; --text-2:#5a6a88; --text-3:#2e3d5c;
  --font-d:'Syne',sans-serif; --font-m:'JetBrains Mono',monospace; --font-b:'DM Sans',sans-serif;
  --r-sm:4px; --r-md:8px; --r-lg:14px; --r-xl:20px;
  --glow-cyan:0 0 24px rgba(56,200,240,0.18),0 0 60px rgba(56,200,240,0.06);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-b);background:var(--bg-0);color:var(--text-0);min-height:100vh;overflow-x:hidden;font-size:14px;line-height:1.6;-webkit-font-smoothing:antialiased}
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(ellipse 80% 50% at 20% -10%,rgba(56,200,240,0.07) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 110%,rgba(240,184,64,0.04) 0%,transparent 60%);pointer-events:none;z-index:0}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.025) 2px,rgba(0,0,0,0.025) 4px);pointer-events:none;z-index:0}
#app{position:relative;z-index:1}

/* ── NAV ── */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;height:60px;background:rgba(4,6,14,.92);backdrop-filter:blur(18px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:0}
.nav-logo{font-family:var(--font-d);font-weight:800;font-size:19px;color:var(--text-0);letter-spacing:-.5px;margin-right:auto;cursor:pointer;display:flex;align-items:center;gap:9px;text-decoration:none;flex-shrink:0}
.nav-logo-icon{width:30px;height:30px;background:linear-gradient(135deg,var(--cyan),#7b5ff0);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;box-shadow:var(--glow-cyan)}
.nav-logo span{color:var(--cyan)}
.nav-links{display:flex;gap:2px;margin-right:14px}
.nav-link{padding:6px 13px;border-radius:4px;font-size:13px;font-weight:500;color:var(--text-1);cursor:pointer;transition:all .15s;border:1px solid transparent;background:none;font-family:var(--font-b)}
.nav-link:hover{color:var(--text-0);background:var(--bg-3)}
.nav-link.active{color:var(--cyan);background:var(--cyan-dim);border-color:var(--border-hi)}

/* UTC clock */
.utc-clock{font-family:var(--font-m);font-size:10px;color:var(--text-2);letter-spacing:.5px;margin-right:12px;padding:4px 10px;border:1px solid var(--border);border-radius:4px;background:var(--bg-2);white-space:nowrap;min-width:158px;text-align:center}

/* Chain tag */
.chain-tag{font-family:var(--font-m);font-size:10px;color:var(--text-2);letter-spacing:1px;margin-right:12px;padding:2px 8px;border:1px solid var(--border);border-radius:4px;white-space:nowrap}

/* Balance pill */
.balance-pill{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--bg-2);font-family:var(--font-m);font-size:12px;color:var(--text-1);transition:color .4s;white-space:nowrap;margin-right:8px}
.balance-pill.flash-down{color:var(--red)!important;border-color:rgba(240,80,96,.3)}
.balance-pill.flash-up{color:var(--green)!important;border-color:rgba(60,240,160,.3)}

/* Wallet buttons */
.wallet-btn-connect{display:flex;align-items:center;gap:7px;padding:8px 16px;border-radius:8px;font-size:13px;font-family:var(--font-d);font-weight:600;cursor:pointer;border:1px solid var(--border-hi);background:var(--cyan-dim);color:var(--cyan);transition:all .2s;white-space:nowrap}
.wallet-btn-connect:hover{background:rgba(56,200,240,.18);box-shadow:var(--glow-cyan)}
.wallet-btn-addr{display:flex;align-items:center;gap:7px;padding:7px 13px;border-radius:8px;font-size:12px;font-family:var(--font-m);cursor:pointer;border:1px solid rgba(60,240,160,.35);background:rgba(60,240,160,.07);color:var(--green);transition:all .15s;white-space:nowrap;position:relative}
.wallet-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:pulse 2s infinite;flex-shrink:0}

/* Disconnect dropdown */
.disconnect-drop{position:absolute;top:calc(100% + 8px);right:0;background:var(--bg-2);border:1px solid var(--border-hi);border-radius:var(--r-lg);min-width:220px;box-shadow:0 12px 40px rgba(0,0,0,.5);overflow:hidden;z-index:200;animation:fadeUp .18s ease both}
.drop-item{padding:11px 16px;font-family:var(--font-m);font-size:12px;cursor:pointer;transition:background .15s;display:flex;justify-content:space-between;align-items:center}
.drop-item:hover{background:var(--bg-3)}
.drop-item.danger{color:var(--red)}
.drop-item.danger:hover{background:var(--red-dim)}

/* Pages */
.page{display:none;padding-top:60px;min-height:100vh}
.page.active{display:block}

/* ── WALLET MODAL ── */
.wallet-modal-overlay{position:fixed;inset:0;z-index:300;background:rgba(4,6,14,.85);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;padding:24px;animation:fadeIn .2s ease both}
.wallet-modal{background:var(--bg-1);border:1px solid var(--border-hi);border-radius:var(--r-xl);width:100%;max-width:420px;box-shadow:0 24px 80px rgba(0,0,0,.5),var(--glow-cyan);animation:fadeUp .22s ease both}
.wallet-option{display:flex;align-items:center;gap:16px;padding:18px 20px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--r-lg);cursor:pointer;transition:all .18s;position:relative;overflow:hidden}
.wallet-option:hover{transform:translateY(-1px)}
.wallet-option.connecting{animation:walletPulse 1.2s infinite}
.wallet-option-logo{width:52px;height:52px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.wallet-badge{font-family:var(--font-m);font-size:9px;padding:2px 6px;border-radius:4px;letter-spacing:.5px}
.wallet-badge.detected{color:var(--green);background:var(--green-dim);border:1px solid rgba(60,240,160,.2)}
.wallet-badge.install{color:var(--gold);background:var(--gold-dim);border:1px solid rgba(240,184,64,.2)}

/* ── LAYOUT ── */
.page-layout{display:grid;grid-template-columns:220px 1fr;min-height:calc(100vh - 60px)}
.sidebar{background:var(--bg-1);border-right:1px solid var(--border);padding:20px 0;position:sticky;top:60px;height:calc(100vh - 60px);overflow-y:auto;display:flex;flex-direction:column}
.sidebar-label{font-family:var(--font-m);font-size:10px;letter-spacing:1.5px;color:var(--text-3);text-transform:uppercase;padding:0 14px;margin-bottom:6px}
.sidebar-item{display:flex;align-items:center;gap:10px;padding:9px 14px;border-radius:var(--r-md);font-size:13px;color:var(--text-1);cursor:pointer;transition:all .15s;border:1px solid transparent;margin:1px 8px}
.sidebar-item:hover{background:var(--bg-3);color:var(--text-0)}
.sidebar-item.active{background:var(--cyan-dim);color:var(--cyan);border-color:rgba(56,200,240,.18)}
.sidebar-badge{margin-left:auto;background:var(--bg-4);color:var(--text-2);font-family:var(--font-m);font-size:10px;padding:2px 6px;border-radius:99px}
.sidebar-item.active .sidebar-badge{background:rgba(56,200,240,.18);color:var(--cyan)}
.page-content{padding:32px;overflow-y:auto;min-width:0}

/* ── CARDS ── */
.card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;transition:border-color .2s}
.card:hover{border-color:var(--border-hi)}
.card-header{padding:17px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.card-title{font-family:var(--font-d);font-weight:600;font-size:15px}
.card-body{padding:22px}

/* ── STAT CARDS ── */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
.stat-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;transition:border-color .2s;position:relative}
.stat-card:hover{border-color:var(--border-hi)}
.stat-card .top-bar{height:2px;width:100%}
.stat-card-inner{padding:20px 22px}
.stat-label{font-family:var(--font-m);font-size:10px;letter-spacing:1px;color:var(--text-2);text-transform:uppercase;margin-bottom:10px}
.stat-value{font-family:var(--font-m);font-size:28px;font-weight:400;margin-bottom:6px;line-height:1;transition:all .4s}
.stat-value.flash{animation:statFlash .6s ease}
.stat-delta{font-family:var(--font-m);font-size:11px;color:var(--text-2)}
.stat-delta.up{color:var(--green)}
.stat-delta.down{color:var(--red)}

/* ── BUTTONS ── */
.btn-primary{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 22px;background:var(--cyan);color:var(--bg-0);border:none;border-radius:var(--r-md);font-family:var(--font-d);font-weight:700;font-size:13px;cursor:pointer;transition:all .2s;box-shadow:var(--glow-cyan);white-space:nowrap}
.btn-primary:hover{background:#5dd8f8;transform:translateY(-1px);box-shadow:0 0 40px rgba(56,200,240,.3)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none}
.btn-secondary{display:inline-flex;align-items:center;gap:8px;padding:10px 22px;background:transparent;color:var(--text-0);border:1px solid var(--border);border-radius:var(--r-md);font-family:var(--font-d);font-weight:600;font-size:13px;cursor:pointer;transition:all .2s;white-space:nowrap}
.btn-secondary:hover{border-color:var(--border-hi);background:var(--bg-3)}
.btn-ghost{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:transparent;color:var(--text-1);border:1px solid var(--border);border-radius:var(--r-md);font-family:var(--font-b);font-weight:500;font-size:12px;cursor:pointer;transition:all .2s;white-space:nowrap}
.btn-ghost:hover{border-color:var(--border-hi);color:var(--text-0);background:var(--bg-3)}
.btn-danger{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:var(--red-dim);color:var(--red);border:1px solid rgba(240,80,96,.25);border-radius:var(--r-md);font-family:var(--font-b);font-weight:500;font-size:12px;cursor:pointer;transition:all .2s;white-space:nowrap}
.btn-danger:hover{background:rgba(240,80,96,.15)}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:var(--r-sm);font-family:var(--font-m);font-size:10px;font-weight:500;letter-spacing:.5px;text-transform:uppercase;white-space:nowrap}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0}
.badge-active{background:var(--green-dim);color:var(--green);border:1px solid rgba(60,240,160,.2)}
.badge-active::before{background:var(--green);box-shadow:0 0 4px var(--green);animation:pulse 2s infinite}
.badge-paused{background:var(--gold-dim);color:var(--gold);border:1px solid rgba(240,184,64,.2)}
.badge-paused::before{background:var(--gold)}
.badge-cancelled{background:var(--red-dim);color:var(--red);border:1px solid rgba(240,80,96,.2)}
.badge-cancelled::before{background:var(--red)}
.badge-inactive{background:var(--bg-3);color:var(--text-2);border:1px solid var(--border)}
.badge-inactive::before{background:var(--text-2)}

/* ── TABLE ── */
.data-table{width:100%;border-collapse:collapse}
.data-table th{font-family:var(--font-m);font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--text-2);padding:11px 16px;text-align:left;border-bottom:1px solid var(--border);background:var(--bg-0);white-space:nowrap}
.data-table td{padding:13px 16px;font-size:13px;border-bottom:1px solid var(--border);white-space:nowrap}
.data-table tbody tr{transition:background .15s;cursor:pointer}
.data-table tbody tr:hover{background:var(--bg-2)}
.data-table tbody tr:last-child td{border-bottom:none}
.td-mono{font-family:var(--font-m);font-size:12px}

/* ── FORMS ── */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.form-group{display:flex;flex-direction:column;gap:6px}
.form-group.span-2{grid-column:span 2}
label.field-label{font-family:var(--font-m);font-size:10px;letter-spacing:1px;color:var(--text-2);text-transform:uppercase}
.input{width:100%;background:var(--bg-0);border:1px solid var(--border);border-radius:var(--r-md);color:var(--text-0);font-family:var(--font-b);font-size:13px;padding:10px 14px;transition:all .15s;outline:none}
.input:focus{border-color:var(--border-hi);box-shadow:0 0 0 3px rgba(56,200,240,.07)}
.input::placeholder{color:var(--text-3)}
select.input{cursor:pointer;-webkit-appearance:none}
textarea.input{resize:vertical;min-height:72px}
.input-wrap{position:relative}
.input-suffix{position:absolute;right:0;top:0;bottom:0;display:flex;align-items:center;padding:0 12px;font-family:var(--font-m);font-size:11px;color:var(--text-2);border-left:1px solid var(--border);background:var(--bg-2);border-radius:0 var(--r-md) var(--r-md) 0;pointer-events:none}
.interval-toggle{display:flex;gap:8px}
.interval-opt{flex:1;padding:10px 8px;text-align:center;background:var(--bg-0);border:1px solid var(--border);border-radius:var(--r-md);font-size:12px;font-family:var(--font-b);color:var(--text-1);cursor:pointer;transition:all .15s}
.interval-opt:hover{border-color:var(--border-hi);color:var(--text-0)}
.interval-opt.selected{background:var(--cyan-dim);border-color:var(--border-hi);color:var(--cyan)}
.token-row{display:flex;gap:8px}
.token-opt{flex:1;padding:10px 14px;background:var(--bg-0);border:1px solid var(--border);border-radius:var(--r-md);font-family:var(--font-m);font-size:13px;cursor:pointer;transition:all .15s;color:var(--text-1);display:flex;align-items:center;gap:8px;justify-content:center}
.token-opt.selected{background:var(--cyan-dim);border-color:var(--border-hi);color:var(--cyan)}
.token-icon{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;z-index:200;background:rgba(4,6,14,.85);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;padding:24px;animation:fadeIn .2s ease both}
.modal{background:var(--bg-1);border:1px solid var(--border-hi);border-radius:var(--r-xl);width:100%;max-width:560px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,.5),var(--glow-cyan);animation:fadeUp .22s ease both}
.modal-header{padding:24px 28px 0;display:flex;align-items:flex-start;justify-content:space-between}
.modal-title{font-family:var(--font-d);font-weight:700;font-size:22px;letter-spacing:-.5px}
.modal-close{width:32px;height:32px;border-radius:8px;background:var(--bg-3);border:1px solid var(--border);color:var(--text-1);cursor:pointer;font-size:18px;line-height:1;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.modal-close:hover{background:var(--bg-4);color:var(--text-0)}
.modal-body{padding:20px 28px 28px}
.breakdown-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px}
.breakdown-row:last-child{border-bottom:none}
.breakdown-row.total{font-family:var(--font-m);font-size:14px;font-weight:500;color:var(--cyan);padding-top:10px}

/* ── PLAN CARDS ── */
.plan-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.plan-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:22px;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;position:relative;overflow:hidden}
.plan-card:hover{border-color:var(--border-hi);background:var(--bg-2);transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,0,0,.3)}

/* ── SUBSCRIPTION CARD ── */
.sub-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px;transition:border-color .2s}
.sub-timeline{display:flex;margin-bottom:18px}
.sub-tl-item{flex:1;padding:11px 14px;background:var(--bg-0);border:1px solid var(--border);border-right:none}
.sub-tl-item:first-child{border-radius:var(--r-md) 0 0 var(--r-md)}
.sub-tl-item:last-child{border-right:1px solid var(--border);border-radius:0 var(--r-md) var(--r-md) 0}
.sub-tl-label{font-family:var(--font-m);font-size:9px;color:var(--text-3);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px}
.sub-tl-val{font-family:var(--font-m);font-size:12px}

/* ── HERO ── */
.hero{min-height:calc(100vh - 60px);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 24px;position:relative;overflow:hidden}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 80% 70% at 50% 50%,black,transparent);opacity:.35}
.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:5px 16px;border:1px solid var(--border-hi);border-radius:99px;background:var(--cyan-dim);font-family:var(--font-m);font-size:11px;color:var(--cyan);letter-spacing:1px;margin-bottom:32px;animation:fadeUp .6s ease both}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(--cyan);box-shadow:0 0 8px var(--cyan);animation:pulse 2s infinite;flex-shrink:0}
.hero-title{font-family:var(--font-d);font-weight:800;font-size:clamp(38px,6vw,72px);line-height:1.0;letter-spacing:-2px;margin-bottom:24px;animation:fadeUp .6s .1s ease both}
.hero-title .grad{background:linear-gradient(90deg,var(--cyan),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:17px;color:var(--text-1);max-width:500px;margin:0 auto 44px;line-height:1.65;font-weight:300;animation:fadeUp .6s .2s ease both}
.hero-ctas{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;animation:fadeUp .6s .3s ease both}
.hero-stats{display:flex;gap:40px;justify-content:center;margin-top:72px;flex-wrap:wrap;animation:fadeUp .6s .4s ease both}
.hero-stat{text-align:center}
.hero-stat-val{font-family:var(--font-m);font-size:26px;font-weight:400;color:var(--cyan);display:block}
.hero-stat-lbl{font-family:var(--font-m);font-size:10px;color:var(--text-2);letter-spacing:1px;text-transform:uppercase}
.hero-stat-div{width:1px;background:var(--border)}

/* ── BAR CHART ── */
.bar-chart{display:flex;align-items:flex-end;gap:6px;height:140px}
.bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;height:100%}
.bar{width:100%;border-radius:4px 4px 0 0;cursor:pointer;transition:opacity .15s;position:relative}
.bar:hover{opacity:.75}
.bar-label{font-family:var(--font-m);font-size:9px;color:var(--text-2);margin-top:6px;letter-spacing:.5px}

/* ── TOAST ── */
.toast-wrap{position:fixed;bottom:28px;right:28px;z-index:999;display:flex;flex-direction:column;gap:10px;width:340px;pointer-events:none}
.toast{background:var(--bg-2);border:1px solid var(--border-hi);border-radius:12px;padding:14px 16px;display:flex;gap:12px;align-items:flex-start;box-shadow:0 8px 32px rgba(0,0,0,.4);animation:fadeUp .3s ease both;pointer-events:all}
.toast-icon{font-size:16px;font-family:var(--font-m);flex-shrink:0}
.toast-title{font-family:var(--font-m);font-size:12px;font-weight:500;margin-bottom:2px}
.toast-sub{font-size:10px;color:var(--text-1);font-family:var(--font-m)}
.toast-x{background:none;border:none;color:var(--text-2);cursor:pointer;font-size:14px;line-height:1;flex-shrink:0;margin-left:auto}

/* ── MISC ── */
.eyebrow{font-family:var(--font-m);font-size:11px;letter-spacing:2px;color:var(--cyan);text-transform:uppercase;margin-bottom:10px}
.notice{background:var(--bg-2);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:var(--r-md);padding:10px 14px;font-size:12px;color:var(--text-1);margin-bottom:18px}
.notice.gold{border-left-color:var(--gold)}
.notice.red{border-left-color:var(--red)}
.addr-chip{display:inline-flex;align-items:center;gap:5px;font-family:var(--font-m);font-size:11px;color:var(--text-1);background:var(--bg-3);border:1px solid var(--border);border-radius:var(--r-sm);padding:3px 8px;cursor:pointer;transition:all .15s}
.addr-chip:hover{border-color:var(--border-hi);color:var(--cyan)}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:var(--bg-0)}
::-webkit-scrollbar-thumb{background:var(--bg-4);border-radius:3px}

/* ── ANIMATIONS ── */
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes walletPulse{0%,100%{opacity:1}50%{opacity:.6}}
@keyframes statFlash{0%{transform:scale(1.08)}100%{transform:scale(1)}}
@keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
@keyframes balanceFlash{0%{opacity:1}30%{opacity:.3}100%{opacity:1}}

@media(max-width:900px){
  .page-layout{grid-template-columns:1fr}
  .sidebar{display:none}
  .stats-row{grid-template-columns:1fr 1fr}
  .plan-grid{grid-template-columns:1fr}
}
</style>
