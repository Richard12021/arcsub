function openChargeModal(subId) {
  const sub = USER_SUBS.find(s => s.id === subId)
  if (!sub) return
  STATE.activeSub = subId
  document.getElementById('charge-modal-body').innerHTML = `
    <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--r-md);padding:14px;margin-bottom:16px">
      <div style="font-family:var(--font-d);font-weight:600;font-size:15px;margin-bottom:4px">${sub.planName}</div>
      <div style="font-family:var(--font-m);font-size:11px;color:var(--text-2)">Sub #${sub.id} · ${sub.interval} · ${sub.payments} payments made</div>
    </div>
    <div style="background:var(--bg-0);border:1px solid var(--border);border-radius:var(--r-md);padding:14px;margin-bottom:18px">
      <div class="breakdown-row"><span style="color:var(--text-1)">Amount</span><span style="font-family:var(--font-m);font-size:12px">${sub.price}.00 ${sub.token}</span></div>
      <div class="breakdown-row"><span style="color:var(--text-1)">Interval</span><span style="font-family:var(--font-m);font-size:12px">${sub.interval}</span></div>
      <div class="breakdown-row total"><span>You pay</span><span>${sub.price}.00 ${sub.token}</span></div>
    </div>
    <div style="display:flex;gap:8px;justify-content:space-between">
      <button class="btn-danger" onclick="cancelSubConfirm(${subId})">Cancel Plan</button>
      <div style="display:flex;gap:8px">
        <button class="btn-ghost" onclick="closeModal('modal-charge')">Close</button>
        <button class="btn-primary" id="charge-btn" onclick="confirmCharge(${subId})">Confirm Payment →</button>
      </div>
    </div>`
  document.getElementById('modal-charge').style.display = ''
}

function confirmCharge(subId) {
  const sub = USER_SUBS.find(s => s.id === subId)
  if (!sub) return
  const btn = document.getElementById('charge-btn')
  btn.disabled=true
  btn.innerHTML='<span style="animation:spin .8s linear infinite;display:inline-block">↻</span> Paying…'
  setTimeout(() => {
    closeModal('modal-charge')
    sub.status   = 'active'
    sub.payments += 1
    sub.next     = 'May 28, 2026'
    deductBalance(sub.price, sub.planName)
    renderDashboard()
  }, 1500)
}

function cancelSubConfirm(subId) {
  const sub = USER_SUBS.find(s => s.id === subId)
  if (!sub) return
  closeModal('modal-charge')
  // tiny gas fee
  deductBalance(0.01, `cancelSubscription(${subId}) · gas`)
  sub.status = 'cancelled'
  toast('Cancelled', `${sub.planName} cancelled on Arc`, '🔴')
  renderDashboard()
}

