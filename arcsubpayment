// ══════════════════════════════════════════════
// WALLET MODAL
// ══════════════════════════════════════════════
function openWalletModal() {
  document.getElementById('wallet-modal').style.display = ''
  document.getElementById('wallet-error').style.display = 'none'
  resetWalletOptions()
}

function closeWalletModal() {
  document.getElementById('wallet-modal').style.display = 'none'
  resetWalletOptions()
}

function resetWalletOptions() {
  ['mm','okx'].forEach(id => {
    const opt = document.getElementById(`${id}-option`)
    if (!opt) return
    opt.style.borderColor = 'var(--border)'
    opt.style.background  = 'var(--bg-2)'
    opt.style.transform   = ''
    document.getElementById(`${id}-shimmer`).style.display = 'none'
    document.getElementById(`${id}-arrow`).style.display   = ''
  })
  const mmDesc  = document.getElementById('mm-desc')
  const okxDesc = document.getElementById('okx-desc')
  if(mmDesc)  mmDesc.textContent  = 'Connect using MetaMask browser extension'
  if(okxDesc) okxDesc.textContent = 'Connect using OKX Wallet browser extension'
}

function connectWallet(type) {
  // Show connecting state
  const id      = type === 'metamask' ? 'mm' : 'okx'
  const color   = type === 'metamask' ? '#F5841F' : '#ffffff'
  const name    = type === 'metamask' ? 'MetaMask' : 'OKX Wallet'
  const opt     = document.getElementById(`${id}-option`)
  const shimmer = document.getElementById(`${id}-shimmer`)
  const arrow   = document.getElementById(`${id}-arrow`)
  const desc    = document.getElementById(`${id}-desc`)

  opt.style.borderColor = color + '60'
  opt.style.background  = type === 'metamask' ? 'rgba(245,132,31,.06)' : 'rgba(255,255,255,.04)'
  shimmer.style.display = ''
  arrow.style.display   = 'none'
  desc.innerHTML = `<span style="color:${color};display:flex;align-items:center;gap:6px"><span style="animation:spin .8s linear infinite;display:inline-block">↻</span> Opening ${name}…</span>`

  document.getElementById('wallet-error').style.display = 'none'

  // Simulate wallet popup + connection (1.6s)
  setTimeout(() => {
    const addr = '0x' + Array.from({length:40}, () => '0123456789abcdef'[Math.floor(Math.random()*16)]).join('')
    STATE.connected = true
    STATE.wallet    = type
    STATE.address   = addr
    closeWalletModal()
    updateWalletUI()
    toast('Connected', `${name} · ${shortAddr(addr)}`, type === 'metamask' ? '🦊' : '⬛')
  }, 1600)
}

// ══════════════════════════════════════════════
// WALLET UI
// ══════════════════════════════════════════════
function shortAddr(a) { return a.slice(0,6)+'…'+a.slice(-4) }

function updateWalletUI() {
  const area = document.getElementById('wallet-area')
  if (STATE.connected) {
    const walletIcon = STATE.wallet === 'okx'
      ? `<svg width="13" height="13" viewBox="0 0 32 32" style="vertical-align:middle"><rect x="4" y="4" width="10" height="10" rx="1.5" fill="currentColor"/><rect x="18" y="4" width="10" height="10" rx="1.5" fill="currentColor"/><rect x="4" y="18" width="10" height="10" rx="1.5" fill="currentColor"/><rect x="18" y="18" width="10" height="10" rx="1.5" fill="currentColor"/></svg>`
      : `<svg width="13" height="13" viewBox="0 0 35 35" style="vertical-align:middle"><path d="M32.9 1L19.4 11.1l2.5-5.9L32.9 1z" fill="#E2761B"/><path d="M2.1 1l13.4 10.2-2.4-6L2.1 1z" fill="#E4761B"/></svg>`

    area.innerHTML = `
      <div style="display:flex;align-items:center;gap:8px;position:relative" id="wallet-connected-area">
        <div class="balance-pill" id="balance-pill">
          ${walletIcon} <span id="balance-display">${STATE.balance.toFixed(2)} USDC</span>
        </div>
        <button class="wallet-btn-addr" onclick="toggleDisconnectDrop(event)">
          <span class="wallet-dot"></span>
          ${shortAddr(STATE.address)}
          <span style="font-size:9px;opacity:.6">▾</span>
        </button>
      </div>`

    // Sidebar wallet info
    document.getElementById('sidebar-addr').textContent = shortAddr(STATE.address)
    document.getElementById('sidebar-balance').textContent = STATE.balance.toFixed(2) + ' USDC'
    document.getElementById('user-sidebar-addr').textContent = shortAddr(STATE.address)
    document.getElementById('user-sidebar-balance').textContent = STATE.balance.toFixed(2) + ' USDC'
  } else {
    area.innerHTML = `<button class="wallet-btn-connect" onclick="openWalletModal()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/></svg>
      Connect Wallet</button>`
    document.getElementById('sidebar-addr').textContent = 'Not connected'
    document.getElementById('sidebar-balance').textContent = '—'
    document.getElementById('user-sidebar-addr').textContent = 'Not connected'
    document.getElementById('user-sidebar-balance').textContent = '—'
  }
}

function toggleDisconnectDrop(e) {
  e.stopPropagation()
  const area = document.getElementById('wallet-connected-area')
  if (!area) return
  const existing = document.getElementById('disconnect-drop')
  if (existing) { existing.remove(); return }

  const wName = STATE.wallet === 'metamask' ? 'MetaMask' : 'OKX Wallet'
  const drop  = document.createElement('div')
  drop.id     = 'disconnect-drop'
  drop.className = 'disconnect-drop'
  drop.innerHTML = `
    <div style="padding:13px 16px;border-bottom:1px solid var(--border);background:var(--bg-3)">
      <div style="font-family:var(--font-m);font-size:10px;color:var(--text-2);margin-bottom:4px;letter-spacing:1px">VIA ${wName.toUpperCase()}</div>
      <div style="font-family:var(--font-m);font-size:13px;color:var(--cyan)">${STATE.address.slice(0,10)}…${STATE.address.slice(-6)}</div>
    </div>
    <div style="padding:11px 16px;border-bottom:1px solid var(--border);font-family:var(--font-m);font-size:12px;display:flex;justify-content:space-between">
      <span style="color:var(--text-2)">USDC Balance</span>
      <span style="color:var(--cyan)" id="drop-balance">${STATE.balance.toFixed(2)} USDC</span>
    </div>
    <div class="drop-item" onclick="window.open('https://testnet.arcscan.app/address/${STATE.address}','_blank');event.stopPropagation()">View on ArcScan <span style="color:var(--cyan);opacity:.7">↗</span></div>
    <div class="drop-item danger" onclick="disconnectWallet();event.stopPropagation()">Disconnect <span>⏻</span></div>`

  // Stop clicks inside the dropdown from bubbling to document close handler
  drop.addEventListener('click', ev => ev.stopPropagation())
  area.appendChild(drop)

  // Register close-on-outside-click on next tick so this same click doesn't trigger it
  setTimeout(() => {
    document.addEventListener('click', closeDropOnOutside)
  }, 0)
}

function closeDropOnOutside() {
  const d = document.getElementById('disconnect-drop')
  if (d) d.remove()
  document.removeEventListener('click', closeDropOnOutside)
}

function disconnectWallet() {
  STATE.connected = false
  STATE.address   = ''
  STATE.wallet    = ''
  updateWalletUI()
  toast('Disconnected','Wallet disconnected','🔌')
}

// ══════════════════════════════════════════════
// BALANCE — immediate deduction with flash
// ══════════════════════════════════════════════
function deductBalance(amount, label) {
  const prev = STATE.balance
  STATE.balance = Math.max(0, STATE.balance - amount)
  flashBalance('down')
  updateBalanceDisplays()
  toast('Payment Confirmed', `${label} · -${amount.toFixed(2)} USDC · tx: 0x${Math.random().toString(16).slice(2,10)}…`, '✅')
}

function updateBalanceDisplays() {
  const disp = document.getElementById('balance-display')
  if (disp) disp.textContent = STATE.balance.toFixed(2) + ' USDC'
  const sb = document.getElementById('sidebar-balance')
  if (sb) sb.textContent = STATE.balance.toFixed(2) + ' USDC'
  const usb = document.getElementById('user-sidebar-balance')
  if (usb) usb.textContent = STATE.balance.toFixed(2) + ' USDC'
  const dropBal = document.getElementById('drop-balance')
  if (dropBal) dropBal.textContent = STATE.balance.toFixed(2) + ' USDC'
}

function flashBalance(direction) {
  const pill = document.getElementById('balance-pill')
  if (!pill) return
  pill.className = `balance-pill flash-${direction}`
  setTimeout(() => { pill.className = 'balance-pill' }, 1800)
}

