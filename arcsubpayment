function renderDSubs() {
  const el = document.getElementById('d-subs')
  if(!el) return
  const active = USER_SUBS.filter(s=>s.status!=='cancelled')
  const spend  = active.reduce((a,s)=>a+s.price,0)
  el.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:26px">
      <div><h1 style="font-family:var(--font-d);font-weight:700;font-size:26px;letter-spacing:-.5px;margin-bottom:4px">My Subscriptions</h1><p style="font-size:13px;color:var(--text-1)">Manage your active plans on Arc</p></div>
      <button class="btn-secondary" onclick="showPage('browse')">+ Find Plans</button>
    </div>
    <div class="stats-row" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">
      ${statCard('Active Plans',String(active.length),'','','linear-gradient(90deg,transparent,var(--cyan),transparent)','var(--cyan)')}
      ${statCard('Monthly Spend','$'+spend.toFixed(2),'','','linear-gradient(90deg,transparent,var(--gold),transparent)','var(--gold)')}
      ${statCard('USDC Balance','$'+STATE.balance.toFixed(2),'Live balance','','linear-gradient(90deg,transparent,var(--green),transparent)','var(--green)')}
    </div>
    <div style="display:flex;flex-direction:column;gap:16px">
    ${USER_SUBS.map(sub => {
      const plan = PLANS.find(p=>p.id===sub.planId)
      const color = plan?.color || 'var(--cyan)'
      const isPaused = sub.status==='paused'
      const isCancelled = sub.status==='cancelled'
      return `
      <div style="background:var(--bg-1);border:1px solid ${isPaused?'rgba(240,184,64,.3)':'var(--border)'};border-radius:var(--r-lg);padding:24px;transition:border-color .2s;opacity:${isCancelled?.6:1}">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px">
          <div>
            <div style="font-family:var(--font-d);font-weight:600;font-size:17px;margin-bottom:4px">${sub.planName}</div>
            <div style="font-family:var(--font-m);font-size:11px;color:var(--text-2)">Plan #${sub.planId} · Sub #${sub.id} · by ${sub.merchant}</div>
          </div>
          <span class="badge badge-${sub.status}">${sub.status}</span>
        </div>
        <div class="sub-timeline">
          ${[
            ['Amount',`$${sub.price} ${sub.token}`,color],
            ['Interval',sub.interval,'var(--text-0)'],
            ['Started',sub.start,'var(--text-0)'],
            ['Next Payment',sub.next,isPaused?'var(--gold)':'var(--text-0)'],
            ['Payments',String(sub.payments),'var(--green)'],
          ].map(([l,v,c])=>`<div class="sub-tl-item"><div class="sub-tl-label">${l}</div><div class="sub-tl-val" style="color:${c}">${v}</div></div>`).join('')}
        </div>
        ${!isCancelled?`<div style="display:flex;gap:8px">
          ${isPaused?`<button class="btn-primary" style="font-size:12px" onclick="openChargeModal(${sub.id})">Retry Payment →</button>`:`<button class="btn-ghost" style="font-size:12px" onclick="openChargeModal(${sub.id})">Charge Next Cycle</button>`}
          <button class="btn-danger" style="font-size:12px" onclick="openChargeModal(${sub.id})">Cancel</button>
        </div>`:'<div style="font-family:var(--font-m);font-size:11px;color:var(--text-2)">This subscription was cancelled.</div>'}
      </div>`}).join('')}
    </div>`
}

function renderDHistory() {
  const el = document.getElementById('d-history')
  if(!el) return
  el.innerHTML = `
    <div style="margin-bottom:26px"><h1 style="font-family:var(--font-d);font-weight:700;font-size:26px;letter-spacing:-.5px;margin-bottom:4px">Payment History</h1><p style="font-size:13px;color:var(--text-1)">All your on-chain transactions</p></div>
    <div class="card">
      <div class="card-header"><span class="card-title">Transactions</span><span style="font-family:var(--font-m);font-size:12px;color:var(--text-2)">${PAYMENT_HISTORY.length} total</span></div>
      <div style="padding:8px 20px">
        ${PAYMENT_HISTORY.map(h=>`
          <div style="display:flex;align-items:center;padding:13px 0;border-bottom:1px solid var(--border);gap:13px">
            <div style="width:34px;height:34px;border-radius:50%;background:${h.status==='success'?'var(--green-dim)':'var(--red-dim)'};display:flex;align-items:center;justify-content:center;font-size:13px;color:${h.status==='success'?'var(--green)':'var(--red)'};flex-shrink:0">${h.status==='success'?'✓':'✗'}</div>
            <div style="flex:1;min-width:0">
              <div style="font-size:13px;font-weight:500;margin-bottom:3px">${h.plan}</div>
              <div style="font-family:var(--font-m);font-size:11px;color:var(--text-2)">${h.date} · ${h.merchant} ${h.tx!=='—'?`· <span style="color:var(--cyan)">${h.tx}</span>`:''}</div>
            </div>
            <div style="font-family:var(--font-m);font-size:13px;font-weight:500;color:${h.status==='success'?'var(--green)':'var(--red)'};flex-shrink:0">${h.status==='success'?'-':''}${h.amount} USDC${h.status==='failed'?'<span style="display:block;font-size:9px;font-weight:400">(FAILED)</span>':''}</div>
          </div>`).join('')}
      </div>
    </div>`
}

