        ${p.merchant.slice(0,8)}…
      </div>
      <div style="font-family:var(--font-d);font-weight:700;font-size:17px;margin-bottom:6px;letter-spacing:-.3px">${p.name}</div>
      <p style="font-size:12px;color:var(--text-1);line-height:1.6;flex:1;margin-bottom:18px">${p.desc}</p>
      <div style="display:flex;align-items:baseline;gap:5px;margin-bottom:14px">
        <span style="font-family:var(--font-m);font-size:24px;color:${p.color}">${p.price}</span>
        <span style="font-family:var(--font-m);font-size:12px;color:var(--text-1)">${p.token}</span>
        <span style="font-family:var(--font-m);font-size:11px;color:var(--text-2)">/ ${p.interval.toLowerCase()}</span>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        ${[p.interval, p.token, p.trial>0?`${p.trial}d trial`:null, `${p.subs} subs`].filter(Boolean).map(t=>`<span style="font-family:var(--font-m);font-size:10px;padding:3px 7px;border-radius:4px;background:var(--bg-3);color:${t.endsWith('trial')?'var(--gold)':'var(--text-1)'};border:1px solid var(--border)">${t}</span>`).join('')}
      </div>
    </div>`).join('')
}

