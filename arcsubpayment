// CREATE PLAN MODAL
// ══════════════════════════════════════════════
function openCreatePlan() { document.getElementById('modal-create').style.display = '' }

function selectInterval(val, el) {
  document.querySelectorAll('.interval-opt').forEach(o => o.classList.remove('selected'))
  el.classList.add('selected')
  STATE.createInterval = val
}

function selectToken(val, el) {
  document.querySelectorAll('.token-opt').forEach(o => o.classList.remove('selected'))
  el.classList.add('selected')
  STATE.createToken = val
  document.getElementById('cp-token-suffix').textContent = val
}

function updateIntervalPreviews() {
  const p = parseFloat(document.getElementById('cp-price')?.value) || 0
  ;['Weekly','Monthly','Annually'].forEach(iv => {
    const el = document.getElementById('prev-' + iv)
    if (el) el.textContent = p > 0 ? `$${p}/${iv.slice(0,2).toLowerCase()}` : '—'
  })
}

function submitCreatePlan() {
  const name  = document.getElementById('cp-name').value.trim()
  const price = parseFloat(document.getElementById('cp-price').value)
  const errEl = document.getElementById('cp-error')
  if (!name)           { errEl.textContent='Plan name is required'; errEl.style.display=''; return }
  if (!price || price<=0) { errEl.textContent='Price must be greater than 0'; errEl.style.display=''; return }
  if (!STATE.connected) { errEl.textContent='Connect your wallet first'; errEl.style.display=''; return }
  errEl.style.display='none'
  const btn = document.getElementById('cp-btn')
  btn.disabled=true
  btn.innerHTML='<span style="animation:spin .8s linear infinite;display:inline-block">↻</span> Deploying…'
  setTimeout(() => {
    closeModal('modal-create')
    btn.disabled=false; btn.innerHTML='Deploy Plan →'
    // Small gas fee
    deductBalance(0.01, `createPlan(${name}) · gas`)
    toast('Plan Created!', `"${name}" is live on Arc Testnet`, '🚀')
    renderMerchant()
  }, 2000)
}

